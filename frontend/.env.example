# Production: full URL of the deployed API, with the /api suffix.
# Leave unset (or as /api) when frontend and backend share a domain.
VITE_API_BASE_URL=https://jgi-ganaka-vidya.onrender.com/api

# Dev only — where the Vite dev proxy forwards /api requests.
# Defaults to http://localhost:5050 if unset.
VITE_DEV_API_PROXY=http://localhost:5050
