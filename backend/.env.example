# MongoDB connection — use the Atlas SRV URI in production.
# If your machine's DNS resolver can't do SRV lookups, switch to the
# direct multi-host form: mongodb://user:pass@host1:27017,host2:27017,host3:27017/db?ssl=true&replicaSet=...&authSource=admin&retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/atmanirbhar?retryWrites=true&w=majority
DB_NAME=atmanirbhar

# JWT — MUST be a long random string in production. Server refuses to boot
# with the placeholder value when NODE_ENV=production.
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
NODE_ENV=production
PORT=5050

# Comma-separated list of allowed frontend origins. Trailing slashes are
# stripped automatically. Use '*' for dev only.
CORS_ORIGIN=https://team-16-nova-creator.netlify.app,http://localhost:5173
